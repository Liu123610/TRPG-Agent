{
  "name": "trpg-agent",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently --names frontend,backend --prefix-colors cyan,magenta \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:frontend": "cd frontend && set CI=true&& pnpm exec vite --clearScreen false",
    "dev:backend": "cd backend && .venv\\Scripts\\python.exe -m uvicorn app.main:app"
  },
  "devDependencies": {
    "@types/three": "^0.183.1",
    "concurrently": "^8.2.2"
  }
}
